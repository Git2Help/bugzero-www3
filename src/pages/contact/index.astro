---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="BugZero | Contact">
  <Header />

  <!-- Hero -->
  <section class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 px-6 overflow-hidden z-10">
    <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
      <div class="relative z-10 space-y-8">
        <div class="inline-block px-3 py-1 bg-yellow-100 border border-yellow-400 rounded-none transform -rotate-1 shadow-sm">
          <span class="font-pixel text-yellow-800 text-lg uppercase tracking-wide">On vous répond</span>
        </div>
        <h1 class="font-pixel text-5xl lg:text-7xl leading-none tracking-tight text-neutral-900 bg-white/50 backdrop-blur-sm lg:bg-transparent lg:backdrop-blur-none p-2 lg:p-0 rounded-lg">
          Contactez<br><span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-500 via-green-500 to-yellow-500">Bugzero</span>
        </h1>
        <p class="text-xl lg:text-2xl text-neutral-600 leading-relaxed max-w-lg bg-white/80 lg:bg-transparent p-2 lg:p-0">
          Une question, un ordi en panne, un projet web ? On vous répond dans l'heure.
        </p>
      </div>
      <div class="relative flex justify-center lg:justify-end animate-float">
        <div class="relative w-full max-w-md bg-blue-500 border-4 border-black rounded-lg p-2 shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] -rotate-3 hover:rotate-0 transition-transform duration-500 z-10">
          <div class="bg-blue-500 border-2 border-blue-400 h-64 flex flex-col items-center justify-center text-white relative overflow-hidden">
            <div class="absolute w-full h-1 bg-white/20 top-10"></div>
            <div class="absolute w-full h-1 bg-white/20 top-20"></div>
            <div class="absolute w-full h-1 bg-white/20 bottom-10"></div>
            <i data-lucide="mail" class="w-20 h-20 mb-4 stroke-[2]"></i>
            <h2 class="font-pixel text-5xl tracking-widest uppercase">Contact</h2>
            <p class="font-sans font-medium mt-2 text-blue-100">À votre écoute</p>
          </div>
          <div class="h-12 bg-blue-600 flex items-center justify-center">
            <div class="w-16 h-2 bg-blue-800 rounded-full"></div>
          </div>
        </div>
        <div class="absolute -z-10 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[140%] h-[140%] border-2 border-dashed border-neutral-300 rounded-full animate-[spin_20s_linear_infinite] opacity-50"></div>
      </div>
    </div>
  </section>

  <!-- Coordonnées + Formulaire -->
  <section class="relative py-24 border-t-2 border-neutral-100 bg-white/50 backdrop-blur-sm z-10">
    <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-12">

      <!-- Coordonnées -->
      <div class="space-y-6">
        <h2 class="font-pixel text-5xl lg:text-6xl tracking-tight mb-6">COORDONNÉES</h2>
        <div class="w-20 h-2 bg-neutral-900 mb-6"></div>

        <a href="tel:+33678565430" class="flex items-center gap-4 bg-white p-6 border-2 border-neutral-100 shadow-sm hover:border-blue-500 transition-colors group">
          <div class="w-12 h-12 bg-red-500 border-2 border-black flex items-center justify-center text-white group-hover:-translate-y-1 transition-transform">
            <i data-lucide="phone" class="w-6 h-6 stroke-[2]"></i>
          </div>
          <div>
            <p class="font-pixel text-lg text-neutral-900 uppercase tracking-wide">Téléphone</p>
            <p class="text-xl text-neutral-700">06 78 56 54 30</p>
          </div>
        </a>

        <a href="mailto:bonjour@bugzero.fr" class="flex items-center gap-4 bg-white p-6 border-2 border-neutral-100 shadow-sm hover:border-blue-500 transition-colors group">
          <div class="w-12 h-12 bg-blue-500 border-2 border-black flex items-center justify-center text-white group-hover:-translate-y-1 transition-transform">
            <i data-lucide="mail" class="w-6 h-6 stroke-[2]"></i>
          </div>
          <div>
            <p class="font-pixel text-lg text-neutral-900 uppercase tracking-wide">Email</p>
            <p class="text-xl text-neutral-700">bonjour@bugzero.fr</p>
          </div>
        </a>

        <div class="flex items-center gap-4 bg-white p-6 border-2 border-neutral-100 shadow-sm">
          <div class="w-12 h-12 bg-green-500 border-2 border-black flex items-center justify-center text-white">
            <i data-lucide="map-pin" class="w-6 h-6 stroke-[2]"></i>
          </div>
          <div>
            <p class="font-pixel text-lg text-neutral-900 uppercase tracking-wide">Adresse</p>
            <p class="text-xl text-neutral-700">9, Allée Lazare Sauvaigo, 98000 Monaco</p>
          </div>
        </div>
      </div>

      <!-- Formulaire -->
      <div class="bg-white p-8 border-2 border-black shadow-[8px_8px_0px_0px_rgba(0,0,0,1)]">
        <h2 class="font-pixel text-4xl tracking-tight mb-6">ENVOYER_UN_MESSAGE</h2>
        <form action="mailto:bonjour@bugzero.fr" method="post" enctype="text/plain" class="space-y-5">
          <div>
            <label class="block font-pixel text-lg uppercase tracking-wide mb-1" for="nom">Nom</label>
            <input id="nom" name="nom" type="text" required class="w-full px-4 py-3 border-2 border-black bg-white font-sans focus:outline-none focus:bg-yellow-50 transition-colors" />
          </div>
          <div>
            <label class="block font-pixel text-lg uppercase tracking-wide mb-1" for="email">Email</label>
            <input id="email" name="email" type="email" required class="w-full px-4 py-3 border-2 border-black bg-white font-sans focus:outline-none focus:bg-yellow-50 transition-colors" />
          </div>
          <div>
            <label class="block font-pixel text-lg uppercase tracking-wide mb-1" for="tel">Téléphone</label>
            <input id="tel" name="tel" type="tel" class="w-full px-4 py-3 border-2 border-black bg-white font-sans focus:outline-none focus:bg-yellow-50 transition-colors" />
          </div>
          <div>
            <label class="block font-pixel text-lg uppercase tracking-wide mb-1" for="message">Message</label>
            <textarea id="message" name="message" rows="5" required class="w-full px-4 py-3 border-2 border-black bg-white font-sans focus:outline-none focus:bg-yellow-50 transition-colors"></textarea>
          </div>
          <button type="submit" class="w-full font-pixel text-2xl uppercase tracking-wide bg-yellow-400 hover:bg-yellow-500 text-neutral-900 border-2 border-black px-6 py-3 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] hover:translate-x-[2px] hover:translate-y-[2px] transition-all">
            Envoyer →
          </button>
        </form>
      </div>

    </div>
  </section>

  <Footer />
</Layout>
