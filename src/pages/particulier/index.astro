---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ButtonPrimary from '../../components/ButtonPrimary.astro';
import ButtonSecondary from '../../components/ButtonSecondary.astro';
import ButtonOffset from '../../components/ButtonOffset.astro';
import ServiceCard from '../../components/ServiceCard.astro';
---

<Layout title="BugZero | Particulier - Dépannage informatique à domicile">
  <Header />

  <!-- 1. Hero -->
  <section class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 px-6 overflow-hidden z-10">
    <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
      <div class="relative z-10 space-y-8">
        <div class="inline-block px-3 py-1 bg-yellow-100 border border-yellow-400 rounded-none transform -rotate-1 shadow-sm">
          <span class="font-pixel text-yellow-800 text-lg uppercase tracking-wide">Dépannage informatique</span>
        </div>
        <h1 class="font-pixel text-6xl lg:text-8xl leading-none tracking-tight text-neutral-900 bg-white/50 backdrop-blur-sm lg:bg-transparent lg:backdrop-blur-none p-2 lg:p-0 rounded-lg">
          VOTRE PC NE<br>MARCHE PLUS ? <span class="text-transparent bg-clip-text bg-gradient-to-r from-red-500 via-orange-500 to-yellow-500">ON S'EN OCCUPE.</span>
        </h1>
        <p class="text-xl lg:text-2xl text-neutral-600 leading-relaxed max-w-lg bg-white/80 lg:bg-transparent p-2 lg:p-0">
          BugZero intervient chez vous à Monaco, Nice et Menton pour résoudre tous vos problèmes informatiques.
        </p>
        <div class="flex flex-wrap gap-4 pt-4">
          <ButtonPrimary>Prendre rendez-vous</ButtonPrimary>
          <ButtonSecondary>Voir nos services</ButtonSecondary>
        </div>
      </div>
      <div class="relative flex justify-center lg:justify-end animate-float">
        <div class="relative w-full max-w-md bg-purple-500 border-4 border-black rounded-lg p-2 shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] rotate-3 hover:rotate-0 transition-transform duration-500 z-10">
          <div class="bg-purple-500 border-2 border-purple-400 h-64 flex flex-col items-center justify-center text-white relative overflow-hidden">
            <div class="absolute w-full h-1 bg-white/20 top-10"></div>
            <div class="absolute w-full h-1 bg-white/20 top-20"></div>
            <div class="absolute w-full h-1 bg-white/20 bottom-10"></div>
            <i data-lucide="laptop" class="w-20 h-20 mb-4 stroke-[2]"></i>
            <h2 class="font-pixel text-5xl tracking-widest uppercase">Assistance</h2>
            <p class="font-sans font-medium mt-2 text-purple-100">Simple, rapide et sans stress</p>
          </div>
          <div class="h-12 bg-purple-600 flex items-center justify-center">
            <div class="w-16 h-2 bg-purple-800 rounded-full"></div>
          </div>
        </div>
        <div class="absolute -z-10 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[140%] h-[140%] border-2 border-dashed border-neutral-300 rounded-full animate-[spin_20s_linear_infinite] opacity-50"></div>
      </div>
    </div>
  </section>

  <!-- 2. Dépannage à distance -->
  <section class="relative py-24 border-t-2 border-neutral-100 bg-white/50 backdrop-blur-sm z-10">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-12 gap-12">
        <div class="lg:col-span-4">
          <div class="lg:sticky lg:top-32">
            <h2 class="font-pixel text-6xl tracking-tight mb-6">DÉPANNAGE_À_DISTANCE</h2>
            <div class="w-20 h-2 bg-neutral-900 mb-6"></div>
            <p class="text-xl text-neutral-500 font-medium">Rapide, sécurisé, efficace.</p>
          </div>
        </div>
        <div class="lg:col-span-8 space-y-6">
          <div class="bg-white p-8 border-2 border-neutral-100 shadow-sm">
            <h3 class="font-sans text-2xl font-semibold mb-4">Connexion sécurisée en 5 minutes</h3>
            <p class="text-lg text-neutral-600">Notre technicien prend le contrôle de votre PC en toute sécurité via une connexion chiffrée. Pas de rendez-vous à poser, pas de déplacement. Comptez environ 30 minutes pour la plupart des dépannages.</p>
            <p class="text-lg text-neutral-600 mt-4">Problèmes courants traités à distance : virus, ralentissements, installation de logiciels, configuration email, impressions, mises à jour Windows.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Dépannage sur site -->
  <section class="relative py-24 bg-neutral-50/90 border-t-2 border-neutral-200 z-10">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-12 gap-12">
        <div class="lg:col-span-4">
          <div class="lg:sticky lg:top-32">
            <h2 class="font-pixel text-6xl tracking-tight mb-6">DÉPANNAGE_SUR_SITE</h2>
            <div class="w-20 h-2 bg-neutral-900 mb-6"></div>
            <p class="text-xl text-neutral-500 font-medium">On se déplace chez vous.</p>
          </div>
        </div>
        <div class="lg:col-span-8 space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div class="bg-red-500 border-2 border-black p-6 flex flex-col items-center justify-center text-center shadow-hard-sm">
              <i data-lucide="map-pin" class="w-10 h-10 text-white mb-2"></i>
              <h3 class="font-pixel text-2xl text-white">Monaco</h3>
              <p class="font-sans text-white/80 text-sm">Intervention sous 24h</p>
            </div>
            <div class="bg-blue-500 border-2 border-black p-6 flex flex-col items-center justify-center text-center shadow-hard-sm">
              <i data-lucide="map-pin" class="w-10 h-10 text-white mb-2"></i>
              <h3 class="font-pixel text-2xl text-white">Nice</h3>
              <p class="font-sans text-white/80 text-sm">Intervention sous 48h</p>
            </div>
            <div class="bg-green-500 border-2 border-black p-6 flex flex-col items-center justify-center text-center shadow-hard-sm">
              <i data-lucide="map-pin" class="w-10 h-10 text-white mb-2"></i>
              <h3 class="font-pixel text-2xl text-white">Menton</h3>
              <p class="font-sans text-white/80 text-sm">Intervention sous 24h</p>
            </div>
          </div>
          <div class="bg-white p-8 border-2 border-neutral-100 shadow-sm">
            <p class="text-lg text-neutral-600">Nous intervenons également dans les Alpes-Maritimes pour les cas nécessitant une présence physique : réparation matérielle, installation de réseau, câblage, configuration d'équipements.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Maintenance préventive -->
  <section class="relative py-24 border-t-2 border-neutral-100 bg-white/50 backdrop-blur-sm z-10">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="font-pixel text-6xl tracking-tight mb-16 text-center">MAINTENANCE_PRÉVENTIVE</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
<ServiceCard bgColor="bg-cyan-500" borderColor="border-black" icon="spray-can" title="Nettoyage &amp; Optimisation" pixel={true} />
<ServiceCard bgColor="bg-red-500" borderColor="border-black" icon="shield" title="Antivirus &amp; Sécurité" pixel={true} />
        <ServiceCard bgColor="bg-blue-500" borderColor="border-black" icon="hard-drive" title="Sauvegarde de données" pixel={true} />
      </div>
    </div>
  </section>

  <!-- 5. Formation -->
  <section class="relative py-24 bg-neutral-50/90 border-t-2 border-neutral-200 z-10">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-12 gap-12">
        <div class="lg:col-span-4">
          <div class="lg:sticky lg:top-32">
            <h2 class="font-pixel text-6xl tracking-tight mb-6">FORMATION</h2>
            <div class="w-20 h-2 bg-neutral-900 mb-6"></div>
            <p class="text-xl text-neutral-500 font-medium">Apprenez à votre rythme, chez vous.</p>
          </div>
        </div>
        <div class="lg:col-span-8 space-y-6">
          <div class="bg-white p-8 border-2 border-neutral-100 shadow-sm">
            <h3 class="font-sans text-2xl font-semibold mb-4">Initiation aux logiciels</h3>
            <p class="text-lg text-neutral-600">Apprenez les bases de Windows, macOS, ou Linux. Navigation internet, email, gestion de fichiers. Formation adaptée aux débutants comme aux utilisateurs avancés.</p>
          </div>
          <div class="bg-white p-8 border-2 border-neutral-100 shadow-sm">
            <h3 class="font-sans text-2xl font-semibold mb-4">Traitement de texte & bureautique</h3>
            <p class="text-lg text-neutral-600">Maîtrisez Word, Excel, PowerPoint et les alternatives libres. Rédaction de courriers, tableaux de calcul, présentations. Formation individuelle ou en petit groupe.</p>
          </div>
          <div class="bg-white p-8 border-2 border-neutral-100 shadow-sm">
            <h3 class="font-sans text-2xl font-semibold mb-4">Logiciels de comptabilité</h3>
            <p class="text-lg text-neutral-600">Initiation aux outils de gestion pour les indépendants et petites entreprises. Tenue de comptes, déclarations, suivi budgétaire.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. Contact -->
  <section class="relative py-32 px-6 z-10">
    <div class="max-w-3xl mx-auto text-center relative z-10">
      <h2 class="font-pixel text-5xl lg:text-7xl tracking-tight mb-12 bg-white/50 backdrop-blur-sm p-4 rounded-xl inline-block">BESOIN D'AIDE ?</h2>
      <div class="flex flex-col gap-6 max-w-sm mx-auto">
        <ButtonOffset href="tel:0678565430" bgColor="bg-red-500" bgDark="bg-red-800" icon="phone" iconClass="fill-current">06 78 56 54 30</ButtonOffset>
        <ButtonOffset href="mailto:contact@bugzero.com" bgColor="bg-blue-500" bgDark="bg-blue-800" icon="mail" iconClass="fill-current">contact@bugzero.com</ButtonOffset>
        <ButtonOffset href="#" bgColor="bg-pink-500" bgDark="bg-pink-800" icon="map-pin">Monaco - Nice - Menton</ButtonOffset>
      </div>
      <p class="mt-8 text-lg text-neutral-500 font-medium">Intervention du lundi au samedi, de 9h à 19h. Urgences possibles.</p>
    </div>
  </section>

  <Footer />
</Layout>