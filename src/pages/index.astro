---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ButtonPrimary from '../components/ButtonPrimary.astro';
import ButtonSecondary from '../components/ButtonSecondary.astro';
import ButtonOffset from '../components/ButtonOffset.astro';
---

<Layout>
  <Header />

  <!-- Hero Section -->
  <section class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 px-6 overflow-hidden z-10">
    <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
      <div class="relative z-10 space-y-8">
        <div class="inline-block px-3 py-1 bg-yellow-100 border border-yellow-400 rounded-none transform -rotate-1 shadow-sm">
          <span class="font-pixel text-yellow-800 text-lg uppercase tracking-wide">Assistance informatique express</span>
        </div>
        <h1 class="font-pixel text-5xl lg:text-7xl leading-none tracking-tight text-neutral-900 bg-white/50 backdrop-blur-sm lg:bg-transparent lg:backdrop-blur-none p-2 lg:p-0 rounded-lg">
          Votre PC plante,<br>votre entreprise est <span class="text-transparent bg-clip-text bg-gradient-to-r from-red-500 via-green-500 to-blue-500">à l'arrêt ?</span>
        </h1>
        <p class="text-xl lg:text-2xl text-neutral-600 leading-relaxed max-w-lg bg-white/80 lg:bg-transparent p-2 lg:p-0">
          Bugzero intervient en 30 minutes. Diagnostic gratuit, solutions immédiates.
        </p>
        <div class="flex flex-wrap gap-4 pt-4">
          <ButtonPrimary href="tel:+33678565430">Je règle mon problème maintenant</ButtonPrimary>
          <ButtonSecondary href="#services">Voir nos services</ButtonSecondary>
        </div>
      </div>
      <div class="relative flex justify-center lg:justify-end animate-float">
        <div class="absolute top-0 right-10 text-purple-500 font-pixel text-4xl animate-bounce z-20">BUG</div>
        <div class="absolute bottom-10 left-0 text-blue-500 font-pixel text-4xl animate-pulse z-20">!</div>
        <div class="relative w-full max-w-md bg-red-500 border-4 border-black rounded-lg p-2 shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] rotate-3 hover:rotate-0 transition-transform duration-500 z-10">
          <div class="bg-red-500 border-2 border-red-400 h-64 flex flex-col items-center justify-center text-white relative overflow-hidden">
            <div class="absolute w-full h-1 bg-white/20 top-10"></div>
            <div class="absolute w-full h-1 bg-white/20 top-20"></div>
            <div class="absolute w-full h-1 bg-white/20 bottom-10"></div>
            <i data-lucide="triangle-alert" class="w-20 h-20 mb-4 stroke-[2]"></i>
            <h2 class="font-pixel text-5xl tracking-widest uppercase">Bug détecté</h2>
            <p class="font-sans font-medium mt-2 text-red-100">On s'en occupe, simplement et rapidement</p>
          </div>
          <div class="h-12 bg-red-600 flex items-center justify-center">
            <div class="w-16 h-2 bg-red-800 rounded-full"></div>
          </div>
        </div>
        <div class="absolute -z-10 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[140%] h-[140%] border-2 border-dashed border-neutral-300 rounded-full animate-[spin_20s_linear_infinite] opacity-50"></div>
      </div>
    </div>
  </section>

  <!-- 3 Cartes Services -->
  <section id="services" class="relative py-24 border-t-2 border-neutral-100 bg-white/50 backdrop-blur-sm z-10">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="font-pixel text-5xl lg:text-6xl tracking-tight mb-16 text-center">NOS_SERVICES</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Particuliers -->
        <a href="/particulier" class="group bg-purple-500 border-2 border-black p-8 flex flex-col items-center justify-center gap-4 text-center shadow-hard-sm hover:shadow-hard hover:-translate-y-1 transition-all duration-300">
          <div class="p-4 border-2 border-white text-white rounded-none">
            <i data-lucide="home" class="w-8 h-8"></i>
          </div>
          <h3 class="font-pixel text-3xl text-white">Particuliers</h3>
          <p class="font-sans text-white/90 leading-relaxed">Dépannage express, installation, conseils. On s'occupe de tout, à distance ou à domicile.</p>
        </a>
        <!-- Professionnels -->
        <a href="/professionnel" class="group bg-blue-500 border-2 border-black p-8 flex flex-col items-center justify-center gap-4 text-center shadow-hard-sm hover:shadow-hard hover:-translate-y-1 transition-all duration-300">
          <div class="p-4 border-2 border-white text-white rounded-none">
            <i data-lucide="building-2" class="w-8 h-8"></i>
          </div>
          <h3 class="font-pixel text-3xl text-white">Professionnels</h3>
          <p class="font-sans text-white/90 leading-relaxed">Infogérance, cybersécurité, visibilité web. Votre service IT clé-en-main, sans engagement.</p>
        </a>
        <!-- Fonds Bleu -->
        <a href="/professionnel/creation-site" class="group bg-cyan-500 border-2 border-black p-8 flex flex-col items-center justify-center gap-4 text-center shadow-hard-sm hover:shadow-hard hover:-translate-y-1 transition-all duration-300">
          <div class="p-4 border-2 border-white text-white rounded-none">
            <i data-lucide="banknote" class="w-8 h-8"></i>
          </div>
          <h3 class="font-pixel text-3xl text-white">Fonds Bleu (Monaco)</h3>
          <p class="font-sans text-white/90 leading-relaxed">Jusqu'à 70% de subventions pour votre site, SEO, appli. On monte le dossier gratuitement.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Pourquoi Bugzero -->
  <section id="about" class="relative py-24 bg-neutral-50/90 border-t-2 border-neutral-200 z-10">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-12 gap-12">
        <div class="lg:col-span-4">
          <div class="lg:sticky lg:top-32">
            <h2 class="font-pixel text-5xl lg:text-6xl tracking-tight mb-6">POURQUOI_NOUS</h2>
            <div class="w-20 h-2 bg-neutral-900 mb-6"></div>
            <p class="text-xl text-neutral-500 font-medium">Pourquoi nos clients nous recommandent.</p>
          </div>
        </div>
        <div class="lg:col-span-8 space-y-6">
          <div class="bg-white p-8 border-2 border-neutral-100 shadow-sm">
            <ul class="space-y-4">
              <li class="flex items-start gap-3">
                <div class="w-3 h-3 mt-2.5 bg-neutral-900 flex-shrink-0"></div>
                <span class="text-lg text-neutral-700"><strong class="text-neutral-900 font-semibold">15 ans d'expertise</strong> à Monaco et PACA.</span>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-3 h-3 mt-2.5 bg-neutral-900 flex-shrink-0"></div>
                <span class="text-lg text-neutral-700"><strong class="text-neutral-900 font-semibold">Intervention en moins de 2h</strong> (appel avant 14h).</span>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-3 h-3 mt-2.5 bg-neutral-900 flex-shrink-0"></div>
                <span class="text-lg text-neutral-700"><strong class="text-neutral-900 font-semibold">800+ dépannages réussis</strong>, 98% de satisfaction.</span>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-3 h-3 mt-2.5 bg-neutral-900 flex-shrink-0"></div>
                <span class="text-lg text-neutral-700"><strong class="text-neutral-900 font-semibold">Partenaires officiels :</strong> Monaco Cloud, Dell, Bitdefender.</span>
              </li>
            </ul>
          </div>
          <!-- Témoignage -->
          <div class="bg-yellow-50 border-2 border-yellow-400 p-8 shadow-hard-sm relative">
            <i data-lucide="quote" class="w-10 h-10 text-yellow-500 mb-4"></i>
            <p class="font-sans text-xl text-neutral-800 leading-relaxed italic">« Frédéric a récupéré tous mes fichiers en 45 minutes. Incroyable réactivité ! »</p>
            <p class="font-pixel text-lg text-neutral-900 mt-4">– Sophie, particulière à Nice</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="relative py-32 px-6 z-10">
    <div class="max-w-3xl mx-auto text-center relative z-10">
      <h2 class="font-pixel text-4xl lg:text-6xl tracking-tight mb-12 bg-white/50 backdrop-blur-sm p-4 rounded-xl inline-block">PRÊT À DIRE ADIEU AUX BUGS ?</h2>
      <div class="flex flex-col gap-6 max-w-sm mx-auto">
        <ButtonOffset href="tel:+33678565430" bgColor="bg-red-500" bgDark="bg-red-800" icon="phone" iconClass="fill-current">06 78 56 54 30</ButtonOffset>
        <ButtonOffset href="mailto:bonjour@bugzero.fr" bgColor="bg-blue-500" bgDark="bg-blue-800" icon="mail" iconClass="fill-current">bonjour@bugzero.fr</ButtonOffset>
        <ButtonOffset href="https://maps.google.com/?q=9+Allée+Lazare+Sauvaigo+98000+Monaco" bgColor="bg-green-500" bgDark="bg-green-800" icon="map-pin">9, Allée Lazare Sauvaigo, Monaco</ButtonOffset>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
