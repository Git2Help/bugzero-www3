---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ButtonPrimary from '../../components/ButtonPrimary.astro';
import ButtonSecondary from '../../components/ButtonSecondary.astro';
import ButtonOffset from '../../components/ButtonOffset.astro';
---

<Layout title="BugZero | Professionnel - Votre partenaire IT à Monaco">
  <Header />

  <!-- 1. Hero -->
  <section class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 px-6 overflow-hidden z-10">
    <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
      <div class="relative z-10 space-y-8">
        <div class="inline-block px-3 py-1 bg-yellow-100 border border-yellow-400 rounded-none transform -rotate-1 shadow-sm">
          <span class="font-pixel text-yellow-800 text-lg uppercase tracking-wide">Solutions professionnelles</span>
        </div>
        <h1 class="font-pixel text-4xl lg:text-6xl leading-none tracking-tight text-neutral-900 bg-white/50 backdrop-blur-sm lg:bg-transparent lg:backdrop-blur-none p-2 lg:p-0 rounded-lg">
          Votre informatique sur-mesure,<br>sans recruter. <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-500 via-cyan-500 to-green-500">Dès 79€ HT/mois.</span>
        </h1>
        <p class="text-xl lg:text-2xl text-neutral-600 leading-relaxed max-w-lg bg-white/80 lg:bg-transparent p-2 lg:p-0">
          Infogérance, cybersécurité, sites web et SEO pour TPE/PME. Concentrez-vous sur votre business.
        </p>
        <div class="flex flex-wrap gap-4 pt-4">
          <ButtonPrimary href="#formules">Voir les formules</ButtonPrimary>
          <ButtonSecondary href="/professionnel/maintenance-pro">Comparer les formules</ButtonSecondary>
        </div>
      </div>
      <div class="relative flex justify-center lg:justify-end animate-float">
        <div class="relative w-full max-w-md bg-blue-500 border-4 border-black rounded-lg p-2 shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] rotate-3 hover:rotate-0 transition-transform duration-500 z-10">
          <div class="bg-blue-500 border-2 border-blue-400 h-64 flex flex-col items-center justify-center text-white relative overflow-hidden">
            <div class="absolute w-full h-1 bg-white/20 top-10"></div>
            <div class="absolute w-full h-1 bg-white/20 top-20"></div>
            <div class="absolute w-full h-1 bg-white/20 bottom-10"></div>
            <i data-lucide="building-2" class="w-20 h-20 mb-4 stroke-[2]"></i>
            <h2 class="font-pixel text-5xl tracking-widest uppercase">IT Pro</h2>
            <p class="font-sans font-medium mt-2 text-blue-100">Solutions adaptées à votre entreprise</p>
          </div>
          <div class="h-12 bg-blue-600 flex items-center justify-center">
            <div class="w-16 h-2 bg-blue-800 rounded-full"></div>
          </div>
        </div>
        <div class="absolute -z-10 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[140%] h-[140%] border-2 border-dashed border-neutral-300 rounded-full animate-[spin_20s_linear_infinite] opacity-50"></div>
      </div>
    </div>
  </section>

  <!-- 2. Formules Maintenance -->
  <section id="formules" class="relative py-24 border-t-2 border-neutral-100 bg-white/50 backdrop-blur-sm z-10">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="font-pixel text-5xl lg:text-6xl tracking-tight mb-16 text-center">FORMULES_MAINTENANCE</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Supervision-Assistance : 79€ -->
        <div class="bg-yellow-50 border-2 border-yellow-400 p-8 flex flex-col items-center text-center shadow-hard-sm hover:shadow-hard transition-shadow relative overflow-hidden">
          <div class="absolute top-0 left-0 w-full h-2 bg-yellow-400"></div>
          <div class="relative z-10 space-y-4">
            <h3 class="font-pixel text-2xl">Supervision-Assistance</h3>
            <span class="font-pixel text-5xl text-neutral-900">79€</span>
            <span class="block font-sans text-neutral-500">/ mois HT</span>
            <p class="text-sm text-neutral-600 font-medium text-left">Supervision 24/7 + Bitdefender + MSP360. Pour les indépendants.</p>
            <a href="mailto:bonjour@bugzero.fr" class="inline-block px-4 py-2 bg-yellow-400 border-2 border-black font-pixel text-lg text-black shadow-hard-sm shadow-hard-hover transition-all duration-200">Choisir</a>
          </div>
        </div>
        <!-- Liberté : 99€ -->
        <div class="bg-green-50 border-2 border-green-400 p-8 flex flex-col items-center text-center shadow-hard-sm hover:shadow-hard transition-shadow relative overflow-hidden">
          <div class="absolute top-0 left-0 w-full h-2 bg-green-400"></div>
          <div class="relative z-10 space-y-4">
            <h3 class="font-pixel text-2xl">Liberté</h3>
            <span class="font-pixel text-5xl text-neutral-900">99€</span>
            <span class="block font-sans text-neutral-500">/ mois HT</span>
            <p class="text-sm text-neutral-600 font-medium text-left">+1 appel mensuel (30 min), 6 tickets, assistance à distance.</p>
            <a href="mailto:bonjour@bugzero.fr" class="inline-block px-4 py-2 bg-green-400 border-2 border-black font-pixel text-lg text-black shadow-hard-sm shadow-hard-hover transition-all duration-200">Choisir</a>
          </div>
        </div>
        <!-- Puissance : 149€ -->
        <div class="bg-blue-50 border-2 border-blue-400 p-8 flex flex-col items-center text-center shadow-hard-sm hover:shadow-hard transition-shadow relative overflow-hidden">
          <div class="absolute top-0 left-0 w-full h-2 bg-blue-400"></div>
          <div class="relative z-10 space-y-4">
            <h3 class="font-pixel text-2xl">Puissance</h3>
            <span class="font-pixel text-5xl text-neutral-900">149€</span>
            <span class="block font-sans text-neutral-500">/ mois HT</span>
            <p class="text-sm text-neutral-600 font-medium text-left">+3 appels/mois, 3h sur site à Monaco et PACA.</p>
            <a href="mailto:bonjour@bugzero.fr" class="inline-block px-4 py-2 bg-blue-400 border-2 border-black font-pixel text-lg text-black shadow-hard-sm shadow-hard-hover transition-all duration-200">Choisir</a>
          </div>
        </div>
        <!-- Illimitée : 249€ -->
        <div class="bg-purple-50 border-2 border-purple-400 p-8 flex flex-col items-center text-center shadow-hard-sm hover:shadow-hard transition-shadow relative overflow-hidden">
          <div class="absolute top-0 left-0 w-full h-2 bg-purple-400"></div>
          <div class="relative z-10 space-y-4">
            <h3 class="font-pixel text-2xl">Illimitée</h3>
            <span class="font-pixel text-5xl text-neutral-900">249€</span>
            <span class="block font-sans text-neutral-500">/ mois HT</span>
            <p class="text-sm text-neutral-600 font-medium text-left">Appels illimités, 1 journée sur site par mois.</p>
            <a href="mailto:bonjour@bugzero.fr" class="inline-block px-4 py-2 bg-purple-400 border-2 border-black font-pixel text-lg text-black shadow-hard-sm shadow-hard-hover transition-all duration-200">Choisir</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. SécuriSite WP Pro -->
  <section class="relative py-24 bg-neutral-50/90 border-t-2 border-neutral-200 z-10">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-12 gap-12">
        <div class="lg:col-span-4">
          <div class="lg:sticky lg:top-32">
            <h2 class="font-pixel text-5xl lg:text-6xl tracking-tight mb-6">SÉCURISITE_WP_PRO</h2>
            <div class="w-20 h-2 bg-neutral-900 mb-6"></div>
            <p class="text-xl text-neutral-500 font-medium">Votre site WordPress inviolable.</p>
          </div>
        </div>
        <div class="lg:col-span-8 space-y-6">
          <div class="bg-white p-8 border-2 border-neutral-100 shadow-sm">
            <h3 class="font-pixel text-4xl text-green-600 mb-2">99€ HT / mois</h3>
            <p class="text-lg text-neutral-600 leading-relaxed">Mises à jour, sécurité, sauvegardes quotidiennes. Garantie anti-piratage.</p>
            <ul class="space-y-2 mt-6 text-neutral-600 font-medium">
              <li class="flex items-start gap-3"><div class="w-2 h-2 mt-2.5 bg-green-500 flex-shrink-0"></div>Mises à jour WordPress, thèmes et extensions</li>
              <li class="flex items-start gap-3"><div class="w-2 h-2 mt-2.5 bg-green-500 flex-shrink-0"></div>Sauvegarde quotidienne cloud</li>
              <li class="flex items-start gap-3"><div class="w-2 h-2 mt-2.5 bg-green-500 flex-shrink-0"></div>Surveillance de sécurité 24/7</li>
            </ul>
            <a href="mailto:bonjour@bugzero.fr" class="inline-block mt-6 px-6 py-3 bg-green-500 border-2 border-black font-pixel text-xl text-white shadow-hard shadow-hard-hover transition-all duration-200">Je sécurise mon site</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Cybersécurité -->
  <section class="relative py-24 border-t-2 border-neutral-100 bg-white/50 backdrop-blur-sm z-10">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-12 gap-12">
        <div class="lg:col-span-4">
          <div class="lg:sticky lg:top-32">
            <h2 class="font-pixel text-5xl lg:text-6xl tracking-tight mb-6">CYBERSÉCURITÉ</h2>
            <div class="w-20 h-2 bg-neutral-900 mb-6"></div>
            <p class="text-xl text-neutral-500 font-medium">Protégez votre entreprise des menaces.</p>
          </div>
        </div>
        <div class="lg:col-span-8 space-y-6">
          <div class="bg-white p-8 border-2 border-neutral-100 shadow-sm">
            <h3 class="font-pixel text-4xl text-red-600 mb-2">Test d'intrusion dès 500€ HT</h3>
            <p class="text-lg text-neutral-600 leading-relaxed mb-6">Rapport complet, conformité RGPD/NIS2.</p>
            <a href="/professionnel/audit-securite" class="inline-block px-6 py-3 bg-red-500 border-2 border-black font-pixel text-xl text-white shadow-hard shadow-hard-hover transition-all duration-200">Découvrir l'audit</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. Visibilité web -->
  <section class="relative py-24 bg-neutral-50/90 border-t-2 border-neutral-200 z-10">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-12 gap-12">
        <div class="lg:col-span-4">
          <div class="lg:sticky lg:top-32">
            <h2 class="font-pixel text-5xl lg:text-6xl tracking-tight mb-6">VISIBILITÉ_WEB</h2>
            <div class="w-20 h-2 bg-neutral-900 mb-6"></div>
            <p class="text-xl text-neutral-500 font-medium">Faites décoller votre présence en ligne.</p>
          </div>
        </div>
        <div class="lg:col-span-8 space-y-6">
          <div class="bg-white p-8 border-2 border-neutral-100 shadow-sm">
            <h3 class="font-sans text-2xl font-semibold mb-4">Création sur mesure & SEO</h3>
            <p class="text-lg text-neutral-600 leading-relaxed mb-2">Création sur mesure, référencement SEO, Google Ads.</p>
            <p class="text-lg text-neutral-600 leading-relaxed mb-4"><strong class="text-neutral-900 font-semibold">Fonds Bleu (30-70% pour Monaco).</strong> 2 mois de maintenance offerts.</p>
            <a href="/professionnel/creation-site" class="inline-block px-6 py-3 bg-cyan-500 border-2 border-black font-pixel text-xl text-white shadow-hard shadow-hard-hover transition-all duration-200">Démarrer mon projet</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. Infogérance -->
  <section class="relative py-24 border-t-2 border-neutral-100 bg-white/50 backdrop-blur-sm z-10">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-12 gap-12">
        <div class="lg:col-span-4">
          <div class="lg:sticky lg:top-32">
            <h2 class="font-pixel text-5xl lg:text-6xl tracking-tight mb-6">INFOGÉRANCE</h2>
            <div class="w-20 h-2 bg-neutral-900 mb-6"></div>
            <p class="text-xl text-neutral-500 font-medium">Toute votre informatique externalisée.</p>
          </div>
        </div>
        <div class="lg:col-span-8 space-y-6">
          <div class="bg-white p-8 border-2 border-neutral-100 shadow-sm">
            <p class="text-lg text-neutral-600 leading-relaxed mb-6">Installation, gestion, sécurité, dépannage. Un interlocuteur unique pour toute votre infrastructure.</p>
            <a href="/professionnel/infogerance" class="inline-block px-6 py-3 bg-purple-500 border-2 border-black font-pixel text-xl text-white shadow-hard shadow-hard-hover transition-all duration-200">Voir le pack infogérance</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 7. Témoignage -->
  <section class="relative py-20 bg-neutral-50/90 border-t-2 border-neutral-200 z-10">
    <div class="max-w-3xl mx-auto px-6">
      <div class="bg-yellow-50 border-2 border-yellow-400 p-8 shadow-hard-sm">
        <i data-lucide="quote" class="w-10 h-10 text-yellow-500 mb-4"></i>
        <p class="font-sans text-xl text-neutral-800 leading-relaxed italic">« Bugzero gère notre parc info depuis 3 ans, zéro souci. »</p>
        <p class="font-pixel text-lg text-neutral-900 mt-4">– Cabinet Avocats Associés, Monaco</p>
      </div>
    </div>
  </section>

  <!-- 8. Contact -->
  <section class="relative py-32 px-6 z-10">
    <div class="max-w-3xl mx-auto text-center relative z-10">
      <h2 class="font-pixel text-4xl lg:text-6xl tracking-tight mb-8 bg-white/50 backdrop-blur-sm p-4 rounded-xl inline-block">VOTRE_DEVIS_PERSONNALISÉ</h2>
      <p class="text-xl text-neutral-600 mb-12">Parlez-nous de votre projet, on vous répond sous 24h.</p>
      <div class="flex flex-col gap-6 max-w-sm mx-auto">
        <ButtonOffset href="mailto:bonjour@bugzero.fr" bgColor="bg-blue-500" bgDark="bg-blue-800" icon="mail" iconClass="fill-current">Demander mon devis personnalisé</ButtonOffset>
        <ButtonOffset href="tel:+33678565430" bgColor="bg-red-500" bgDark="bg-red-800" icon="phone" iconClass="fill-current">06 78 56 54 30</ButtonOffset>
        <ButtonOffset href="https://maps.google.com/?q=9+Allée+Lazare+Sauvaigo+98000+Monaco" bgColor="bg-green-500" bgDark="bg-green-800" icon="map-pin">9, Allée Lazare Sauvaigo, Monaco</ButtonOffset>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
