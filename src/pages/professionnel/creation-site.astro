---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ButtonPrimary from '../../components/ButtonPrimary.astro';
import ButtonOffset from '../../components/ButtonOffset.astro';
---

<Layout title="BugZero | Création de site internet - Fonds Bleu Monaco">
  <Header />

  <!-- Hero -->
  <section class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 px-6 overflow-hidden z-10">
    <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
      <div class="relative z-10 space-y-8">
        <div class="inline-block px-3 py-1 bg-yellow-100 border border-yellow-400 rounded-none transform -rotate-1 shadow-sm">
          <span class="font-pixel text-yellow-800 text-lg uppercase tracking-wide">Création de site</span>
        </div>
        <h1 class="font-pixel text-4xl lg:text-6xl leading-none tracking-tight text-neutral-900 bg-white/50 backdrop-blur-sm lg:bg-transparent lg:backdrop-blur-none p-2 lg:p-0 rounded-lg">
          Un site internet qui<br>vous rapporte des <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-500 via-blue-500 to-green-500">clients.</span>
        </h1>
        <p class="text-xl lg:text-2xl text-neutral-600 leading-relaxed max-w-lg bg-white/80 lg:bg-transparent p-2 lg:p-0">
          Créé sur mesure. Jusqu'à 70% de subvention grâce au Fonds Bleu Monaco. 2 mois de maintenance offerts.
        </p>
        <div class="flex flex-wrap gap-4 pt-4">
          <ButtonPrimary href="mailto:bonjour@bugzero.fr">Je veux mon site</ButtonPrimary>
        </div>
      </div>
      <div class="relative flex justify-center lg:justify-end animate-float">
        <div class="relative w-full max-w-md bg-cyan-500 border-4 border-black rounded-lg p-2 shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] rotate-3 hover:rotate-0 transition-transform duration-500 z-10">
          <div class="bg-cyan-500 border-2 border-cyan-400 h-64 flex flex-col items-center justify-center text-white relative overflow-hidden">
            <div class="absolute w-full h-1 bg-white/20 top-10"></div>
            <div class="absolute w-full h-1 bg-white/20 top-20"></div>
            <div class="absolute w-full h-1 bg-white/20 bottom-10"></div>
            <i data-lucide="globe" class="w-20 h-20 mb-4 stroke-[2]"></i>
            <h2 class="font-pixel text-5xl tracking-widest uppercase">Web</h2>
            <p class="font-sans font-medium mt-2 text-cyan-100">Votre vitrine en ligne</p>
          </div>
          <div class="h-12 bg-cyan-600 flex items-center justify-center">
            <div class="w-16 h-2 bg-cyan-800 rounded-full"></div>
          </div>
        </div>
        <div class="absolute -z-10 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[140%] h-[140%] border-2 border-dashed border-neutral-300 rounded-full animate-[spin_20s_linear_infinite] opacity-50"></div>
      </div>
    </div>
  </section>

  <!-- Ce que nous créons -->
  <section class="relative py-24 border-t-2 border-neutral-100 bg-white/50 backdrop-blur-sm z-10">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-12 gap-12">
        <div class="lg:col-span-4">
          <div class="lg:sticky lg:top-32">
            <h2 class="font-pixel text-5xl lg:text-6xl tracking-tight mb-6">NOS_CRÉATIONS</h2>
            <div class="w-20 h-2 bg-neutral-900 mb-6"></div>
            <p class="text-xl text-neutral-500 font-medium">Ce que nous créons pour vous.</p>
          </div>
        </div>
        <div class="lg:col-span-8 space-y-6">
          <div class="bg-white p-8 border-2 border-neutral-100 shadow-sm flex items-start gap-4">
            <div class="p-3 border-2 border-black bg-cyan-500 text-white flex-shrink-0">
              <i data-lucide="shopping-bag" class="w-8 h-8"></i>
            </div>
            <p class="text-lg text-neutral-700">Sites vitrines, e-commerce, réservation en ligne.</p>
          </div>
          <div class="bg-white p-8 border-2 border-neutral-100 shadow-sm flex items-start gap-4">
            <div class="p-3 border-2 border-black bg-blue-500 text-white flex-shrink-0">
              <i data-lucide="smartphone" class="w-8 h-8"></i>
            </div>
            <p class="text-lg text-neutral-700">Design responsive, optimisé mobile.</p>
          </div>
          <div class="bg-white p-8 border-2 border-neutral-100 shadow-sm flex items-start gap-4">
            <div class="p-3 border-2 border-black bg-green-500 text-white flex-shrink-0">
              <i data-lucide="search" class="w-8 h-8"></i>
            </div>
            <p class="text-lg text-neutral-700">Référencement SEO intégré (mots-clés, contenu, balisage).</p>
          </div>
          <div class="bg-white p-8 border-2 border-neutral-100 shadow-sm flex items-start gap-4">
            <div class="p-3 border-2 border-black bg-purple-500 text-white flex-shrink-0">
              <i data-lucide="link" class="w-8 h-8"></i>
            </div>
            <p class="text-lg text-neutral-700">Formulaires de contact, liens réseaux sociaux, blog.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Votre projet en 3 étapes -->
  <section class="relative py-24 bg-neutral-50/90 border-t-2 border-neutral-200 z-10">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="font-pixel text-5xl lg:text-6xl tracking-tight mb-16 text-center">VOTRE_PROJET_EN_3_ÉTAPES</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white p-8 border-2 border-black shadow-hard-sm text-center">
          <div class="font-pixel text-6xl text-yellow-500 mb-4">1</div>
          <h3 class="font-pixel text-2xl mb-2">Brief découverte</h3>
          <p class="text-lg text-neutral-600">Gratuit, 30 min.</p>
        </div>
        <div class="bg-white p-8 border-2 border-black shadow-hard-sm text-center">
          <div class="font-pixel text-6xl text-green-500 mb-4">2</div>
          <h3 class="font-pixel text-2xl mb-2">Maquette & validation</h3>
          <p class="text-lg text-neutral-600">Sous 7 jours.</p>
        </div>
        <div class="bg-white p-8 border-2 border-black shadow-hard-sm text-center">
          <div class="font-pixel text-6xl text-blue-500 mb-4">3</div>
          <h3 class="font-pixel text-2xl mb-2">Mise en ligne</h3>
          <p class="text-lg text-neutral-600">Et formation à la mise à jour.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Fonds Bleu -->
  <section class="relative py-24 border-t-2 border-neutral-100 bg-white/50 backdrop-blur-sm z-10">
    <div class="max-w-7xl mx-auto px-6">
      <div class="bg-cyan-50 border-2 border-cyan-400 p-8 shadow-hard-sm max-w-3xl mx-auto text-center">
        <i data-lucide="banknote" class="w-12 h-12 text-cyan-600 mx-auto mb-4"></i>
        <h3 class="font-pixel text-3xl text-cyan-700 mb-4">FONDS_BLEU_MONACO</h3>
        <p class="text-lg text-neutral-700 leading-relaxed">Vous êtes une entreprise monégasque ? L'État prend en charge 30 à 70% du coût. Nous montons le dossier avec vous.</p>
      </div>
    </div>
  </section>

  <!-- Témoignage -->
  <section class="relative py-20 bg-neutral-50/90 border-t-2 border-neutral-200 z-10">
    <div class="max-w-3xl mx-auto px-6">
      <div class="bg-yellow-50 border-2 border-yellow-400 p-8 shadow-hard-sm">
        <i data-lucide="quote" class="w-10 h-10 text-yellow-500 mb-4"></i>
        <p class="font-sans text-xl text-neutral-800 leading-relaxed italic">« Bugzero a créé notre boutique en ligne en 3 semaines. Nos ventes ont triplé. »</p>
        <p class="font-pixel text-lg text-neutral-900 mt-4">– Commerçant à Monaco</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-32 px-6 z-10">
    <div class="max-w-3xl mx-auto text-center relative z-10">
      <h2 class="font-pixel text-4xl lg:text-6xl tracking-tight mb-12 bg-white/50 backdrop-blur-sm p-4 rounded-xl inline-block">DÉMARRER_MON_PROJET</h2>
      <div class="flex flex-col gap-6 max-w-sm mx-auto">
        <ButtonOffset href="mailto:bonjour@bugzero.fr" bgColor="bg-cyan-500" bgDark="bg-cyan-800" icon="mail" iconClass="fill-current">Démarrer mon projet</ButtonOffset>
        <ButtonOffset href="tel:+33678565430" bgColor="bg-red-500" bgDark="bg-red-800" icon="phone" iconClass="fill-current">06 78 56 54 30</ButtonOffset>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
