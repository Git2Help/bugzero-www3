---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ButtonPrimary from '../../components/ButtonPrimary.astro';
import ButtonOffset from '../../components/ButtonOffset.astro';
---

<Layout title="BugZero | Qui sommes-nous">
  <Header />

  <!-- Hero -->
  <section class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 px-6 overflow-hidden z-10">
    <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
      <div class="relative z-10 space-y-8">
        <div class="inline-block px-3 py-1 bg-yellow-100 border border-yellow-400 rounded-none transform -rotate-1 shadow-sm">
          <span class="font-pixel text-yellow-800 text-lg uppercase tracking-wide">Notre histoire</span>
        </div>
        <h1 class="font-pixel text-5xl lg:text-7xl leading-none tracking-tight text-neutral-900 bg-white/50 backdrop-blur-sm lg:bg-transparent lg:backdrop-blur-none p-2 lg:p-0 rounded-lg">
          Qui se cache<br>derrière <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-500 via-green-500 to-yellow-500">Bugzero ?</span>
        </h1>
        <p class="text-xl lg:text-2xl text-neutral-600 leading-relaxed max-w-lg bg-white/80 lg:bg-transparent p-2 lg:p-0">
          Une équipe monégasque de passionnés, à votre service depuis 15 ans.
        </p>
        <div class="flex flex-wrap gap-4 pt-4">
          <ButtonPrimary href="tel:+33678565430">Nous appeler</ButtonPrimary>
        </div>
      </div>
      <div class="relative flex justify-center lg:justify-end animate-float">
        <div class="relative w-full max-w-md bg-green-500 border-4 border-black rounded-lg p-2 shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] rotate-3 hover:rotate-0 transition-transform duration-500 z-10">
          <div class="bg-green-500 border-2 border-green-400 h-64 flex flex-col items-center justify-center text-white relative overflow-hidden">
            <div class="absolute w-full h-1 bg-white/20 top-10"></div>
            <div class="absolute w-full h-1 bg-white/20 top-20"></div>
            <div class="absolute w-full h-1 bg-white/20 bottom-10"></div>
            <i data-lucide="users" class="w-20 h-20 mb-4 stroke-[2]"></i>
            <h2 class="font-pixel text-5xl tracking-widest uppercase">Équipe</h2>
            <p class="font-sans font-medium mt-2 text-green-100">Des passionnés à votre écoute</p>
          </div>
          <div class="h-12 bg-green-600 flex items-center justify-center">
            <div class="w-16 h-2 bg-green-800 rounded-full"></div>
          </div>
        </div>
        <div class="absolute -z-10 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[140%] h-[140%] border-2 border-dashed border-neutral-300 rounded-full animate-[spin_20s_linear_infinite] opacity-50"></div>
      </div>
    </div>
  </section>

  <!-- Présentation -->
  <section class="relative py-24 border-t-2 border-neutral-100 bg-white/50 backdrop-blur-sm z-10">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-12 gap-12">
        <div class="lg:col-span-4">
          <div class="lg:sticky lg:top-32">
            <h2 class="font-pixel text-5xl lg:text-6xl tracking-tight mb-6">NOTRE_HISTOIRE</h2>
            <div class="w-20 h-2 bg-neutral-900 mb-6"></div>
            <p class="text-xl text-neutral-500 font-medium">15 ans à rendre l'informatique simple.</p>
          </div>
        </div>
        <div class="lg:col-span-8 space-y-6">
          <div class="bg-white p-8 border-2 border-neutral-100 shadow-sm">
            <p class="text-lg text-neutral-600 leading-relaxed">Bugzero est la marque grand public et professionnelle d'<a href="https://www.helperiance.com" class="text-blue-600 underline">Helperiance (www.helperiance.com)</a>, société fondée en 2010 par Johan Chauvet (CEO) et Lyonel Sireuille (associé).</p>
          </div>
          <div class="bg-white p-8 border-2 border-neutral-100 shadow-sm">
            <h3 class="font-sans text-2xl font-semibold mb-4">Notre mission</h3>
            <p class="text-lg text-neutral-600 leading-relaxed">Rendre l'informatique simple, fiable et sécurisée pour les particuliers comme pour les entreprises.</p>
          </div>
          <div class="bg-white p-8 border-2 border-neutral-100 shadow-sm">
            <h3 class="font-sans text-2xl font-semibold mb-4">Notre territoire</h3>
            <p class="text-lg text-neutral-600 leading-relaxed">Basés au 9, Allée Lazare Sauvaigo à Monaco, nous intervenons dans tout le bassin monégasque, de Nice à Menton.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Équipe & Partenaires -->
  <section class="relative py-24 bg-neutral-50/90 border-t-2 border-neutral-200 z-10">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="font-pixel text-5xl lg:text-6xl tracking-tight mb-16 text-center">ÉQUIPE_&_PARTENAIRES</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
        <div class="bg-white p-6 border-2 border-neutral-100 shadow-sm text-center">
          <i data-lucide="user" class="w-12 h-12 mx-auto mb-3 text-blue-500"></i>
          <h3 class="font-pixel text-2xl">Johan Chauvet</h3>
          <p class="text-neutral-600">CEO & fondateur</p>
        </div>
        <div class="bg-white p-6 border-2 border-neutral-100 shadow-sm text-center">
          <i data-lucide="user" class="w-12 h-12 mx-auto mb-3 text-green-500"></i>
          <h3 class="font-pixel text-2xl">Lyonel Sireuille</h3>
          <p class="text-neutral-600">Associé</p>
        </div>
        <div class="bg-white p-6 border-2 border-neutral-100 shadow-sm text-center">
          <i data-lucide="user" class="w-12 h-12 mx-auto mb-3 text-red-500"></i>
          <h3 class="font-pixel text-2xl">Frédéric</h3>
          <p class="text-neutral-600">Technicien support</p>
        </div>
        <div class="bg-white p-6 border-2 border-neutral-100 shadow-sm text-center">
          <i data-lucide="user" class="w-12 h-12 mx-auto mb-3 text-purple-500"></i>
          <h3 class="font-pixel text-2xl">Alex</h3>
          <p class="text-neutral-600">Développeur</p>
        </div>
        <div class="bg-white p-6 border-2 border-neutral-100 shadow-sm text-center">
          <i data-lucide="user" class="w-12 h-12 mx-auto mb-3 text-pink-500"></i>
          <h3 class="font-pixel text-2xl">Camelia</h3>
          <p class="text-neutral-600">Développeuse</p>
        </div>
      </div>
      <div class="bg-white p-8 border-2 border-neutral-100 shadow-sm max-w-3xl mx-auto">
        <h3 class="font-sans text-2xl font-semibold mb-4">Nos partenaires</h3>
        <p class="text-lg text-neutral-600 leading-relaxed">Bugzero s'appuie sur des partenaires de confiance : Monaco Cloud, Dell, Bitdefender, The Idea Starter.</p>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="relative py-32 px-6 z-10">
    <div class="max-w-3xl mx-auto text-center relative z-10">
      <h2 class="font-pixel text-4xl lg:text-6xl tracking-tight mb-8 bg-white/50 backdrop-blur-sm p-4 rounded-xl inline-block">PARLONS-NOUS</h2>
      <p class="text-xl text-neutral-600 mb-12">06 78 56 54 30 | bonjour@bugzero.fr</p>
      <div class="flex flex-col gap-6 max-w-sm mx-auto">
        <ButtonOffset href="tel:+33678565430" bgColor="bg-red-500" bgDark="bg-red-800" icon="phone" iconClass="fill-current">06 78 56 54 30</ButtonOffset>
        <ButtonOffset href="mailto:bonjour@bugzero.fr" bgColor="bg-blue-500" bgDark="bg-blue-800" icon="mail" iconClass="fill-current">bonjour@bugzero.fr</ButtonOffset>
        <ButtonOffset href="https://maps.google.com/?q=9+Allée+Lazare+Sauvaigo+98000+Monaco" bgColor="bg-green-500" bgDark="bg-green-800" icon="map-pin">9, Allée Lazare Sauvaigo, Monaco</ButtonOffset>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
