---
// Layout principal BugZero
// Contient <head>, CDN, fonts, styles globaux, floating icons background et footer
export interface Props {
  title?: string;
}

const { title = "BugZero | Assistance et dépannage informatique" } = Astro.props;
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <script src="https://cdn.tailwindcss.com" is:inline></script>
    <script src="https://unpkg.com/lucide@latest" is:inline></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" is:inline />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="" is:inline />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=VT323&display=swap" rel="stylesheet" is:inline />
    <style is:inline>
      .font-pixel { font-family: 'VT323', monospace; }
      .font-sans { font-family: 'Inter', sans-serif; }
      .shadow-hard { box-shadow: 4px 4px 0px 0px rgba(0,0,0,1); }
      .shadow-hard-sm { box-shadow: 2px 2px 0px 0px rgba(0,0,0,1); }
      .shadow-hard-hover:hover { box-shadow: 6px 6px 0px 0px rgba(0,0,0,1); transform: translate(-2px, -2px); }
      .shadow-hard-active:active { box-shadow: 0px 0px 0px 0px rgba(0,0,0,1); transform: translate(4px, 4px); }
      .bg-grid {
        background-size: 40px 40px;
        background-image: linear-gradient(to right, #f0f0f0 1px, transparent 1px),
        linear-gradient(to bottom, #f0f0f0 1px, transparent 1px);
      }
      @keyframes float {
        0% { transform: translateY(0px) rotate(0deg); }
        50% { transform: translateY(-20px) rotate(5deg); }
        100% { transform: translateY(0px) rotate(0deg); }
      }
      .animate-float { animation: float 8s ease-in-out infinite; }
      .animate-float-slow { animation: float 12s ease-in-out infinite; }
      .animate-float-fast { animation: float 6s ease-in-out infinite; }
    </style>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' fill='%230ba5dc'/%3E%3Cpath fill='%23c8d900' d='M24 8h24v40H24z'/%3E%3Crect x='31' y='17' width='10' height='8' fill='white'/%3E%3Cpath fill='%230ba5dc' d='M32 37c3 4 7 4 10 0v5c-3 3-7 3-10 0zM38 51h7v6h-7zM47 47h6v6h-6zM53 53h6v6h-6z'/%3E%3C/svg%3E" />
  </head>
  <body class="font-sans text-neutral-900 bg-white bg-grid antialiased overflow-x-hidden relative">
    <!-- Background Floating Icons Layer -->
    <div class="fixed inset-0 z-0 pointer-events-none overflow-hidden select-none">
      <div class="absolute top-[15%] left-[5%] text-blue-500/10 animate-float-slow" style="animation-delay: 0s;">
        <i data-lucide="wifi" class="w-32 h-32 md:w-48 md:h-48 stroke-[1.5]"></i>
      </div>
      <div class="absolute top-[25%] right-[8%] text-red-500/10 animate-float" style="animation-delay: 2s;">
        <i data-lucide="triangle-alert" class="w-24 h-24 md:w-40 md:h-40 stroke-[1.5]"></i>
      </div>
      <div class="absolute bottom-[20%] left-[8%] text-purple-500/10 animate-float-fast" style="animation-delay: 1s;">
        <i data-lucide="gamepad-2" class="w-40 h-40 md:w-64 md:h-64 stroke-[1.5]"></i>
      </div>
      <div class="absolute bottom-[10%] right-[15%] text-green-500/10 animate-float-slow" style="animation-delay: 3s;">
        <i data-lucide="database" class="w-20 h-20 md:w-32 md:h-32 stroke-[1.5]"></i>
      </div>
      <div class="absolute top-[60%] left-[50%] -translate-x-1/2 text-cyan-500/10 animate-float" style="animation-delay: 4s;">
        <i data-lucide="globe" class="w-48 h-48 md:w-80 md:h-80 stroke-[1.5]"></i>
      </div>
      <div class="absolute top-[5%] left-[40%] text-yellow-500/10 animate-float-fast" style="animation-delay: 1.5s;">
        <i data-lucide="cpu" class="w-16 h-16 md:w-24 md:h-24 stroke-[1.5]"></i>
      </div>
    </div>

    <slot />

    <script is:inline>lucide.createIcons();</script>
  </body>
</html>