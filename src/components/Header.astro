---
// Header / Navbar fixe avec navigation entre les pages
import BugZeroLogo from './BugZeroLogo.astro';
---

<nav class="fixed top-0 w-full z-50 bg-white/90 backdrop-blur-md border-b-2 border-neutral-100">
  <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-1 group">
      <BugZeroLogo />
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-6">
      <a href="/particulier" class="font-pixel text-xl hover:text-blue-600 transition-colors">
        Particulier
      </a>
      <a href="/professionnel" class="font-pixel text-xl hover:text-blue-600 transition-colors">
        Professionnel
      </a>
      <a href="/#about" class="font-pixel text-xl hover:text-blue-600 transition-colors">
        Pourquoi BugZero
      </a>
      <a href="/#contact" class="px-4 py-2 bg-neutral-900 text-white font-pixel text-xl shadow-hard hover:bg-neutral-800 transition-all shadow-hard-hover">
        Nous contacter
      </a>
    </div>

    <!-- Mobile Menu Icon -->
    <button class="md:hidden p-2 border-2 border-black shadow-hard-sm bg-white">
      <i data-lucide="menu" class="w-6 h-6"></i>
    </button>
  </div>
</nav>