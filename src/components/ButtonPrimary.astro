---
// Bouton principal style "hard shadow"
export interface Props {
  href?: string;
  class?: string;
}

const { href, class: className = "" } = Astro.props;
const classes = "px-8 py-4 bg-yellow-400 border-2 border-black font-pixel text-2xl text-black shadow-hard shadow-hard-hover transition-all duration-200 " + className;
---

{href ? (
  <a href={href} class={classes}>
    <slot />
  </a>
) : (
  <button class={classes}>
    <slot />
  </button>
)}
